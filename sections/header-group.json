    "custom_liquid_7Atrpt": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n#summoned-bar{\n  position:sticky;\n  top:0;\n  left:0;\n  width:100%;\n  background:#890000;\n  color:#f2efe9;\n  z-index:99999;\n  display:none;\n  justify-content:center;\n  align-items:center;\n  gap:12px;\n  padding:12px 20px;\n  font-size:14px;\n  font-weight:700;\n  text-align:center;\n  letter-spacing:.3px;\n}\n\n#summoned-timer{\n  background:black;\n  padding:6px 10px;\n  border-radius:5px;\n  min-width:64px;\n  font-variant-numeric:tabular-nums;\n}\n</style>\n\n<div id=\"summoned-bar\">\n  <span>\n    YOUR DISCOUNT IS ACTIVATED. CHECKOUT NOW FOR A FREE TEE, JUST PAY SHIPPING.\n  </span>\n\n  <span id=\"summoned-timer\">10:00</span>\n</div>\n\n<script>\n(function(){\n\nconst STORAGE_KEY = \"summoned_end\";\nconst DURATION = 10 * 60 * 1000;\n\nconst url = window.location.href.toUpperCase();\n\nif(url.includes(\"SUMMONED\")){\n    if(!sessionStorage.getItem(STORAGE_KEY)){\n        sessionStorage.setItem(\n            STORAGE_KEY,\n            Date.now() + DURATION\n        );\n    }\n}\n\nconst end = Number(sessionStorage.getItem(STORAGE_KEY));\n\nif(!end) return;\n\nconst bar = document.getElementById(\"summoned-bar\");\nconst timer = document.getElementById(\"summoned-timer\");\n\nbar.style.display = \"flex\";\n\nfunction update(){\n\n    const remaining = end - Date.now();\n\n    if(remaining <= 0){\n        sessionStorage.removeItem(STORAGE_KEY);\n        bar.remove();\n        return;\n    }\n\n    const mins = Math.floor(remaining / 60000);\n    const secs = Math.floor((remaining % 60000)/1000);\n\n    timer.textContent =\n        String(mins).padStart(2,\"0\") +\n        \":\" +\n        String(secs).padStart(2,\"0\");\n}\n\nupdate();\nsetInterval(update,1000);\n\n})();\n</script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
